{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "reconciled-client-record-v3",
  "title": "ReconciledClientRecord",
  "description": "Structured client record built from all available sources. Every field carries its source, confidence level, and verification state. Null fields mean the source was not provided -- an explicit data state distinct from unknown.",
  "type": "object",
  "required": [
    "client_id",
    "review_date",
    "client_type",
    "effective_risk_level",
    "source_inventory",
    "dimension_confidence",
    "identity",
    "ownership",
    "ubos",
    "screening",
    "financial_risk",
    "documents",
    "client_stated",
    "conflicts",
    "data_quality_flags"
  ],
  "properties": {
    "client_id": {
      "type": "string"
    },
    "review_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "prior_review_date": {
      "type": [
        "string",
        "null"
      ]
    },
    "client_type": {
      "type": "string",
      "enum": [
        "individual-retail",
        "corporate-business",
        "trust-foundation",
        "financial-institution",
        "pep"
      ]
    },
    "client_type_confidence": {
      "type": "string",
      "enum": [
        "confirmed-by-independent-source",
        "confirmed-by-client-document",
        "client-stated-unverified"
      ]
    },
    "pep_overlay_applies": {
      "type": "boolean"
    },
    "pep_overlay_confidence": {
      "type": "string",
      "enum": [
        "confirmed-lexisnexis",
        "client-stated-unverified",
        "not-determined-source-absent"
      ]
    },
    "effective_risk_level": {
      "type": "string",
      "enum": [
        "sdd",
        "standard",
        "edd"
      ]
    },
    "effective_risk_level_confidence": {
      "type": "string",
      "enum": [
        "full",
        "reduced",
        "limited"
      ]
    },
    "source_inventory": {
      "type": "object",
      "description": "Availability status of every source type for this review.",
      "properties": {
        "moodys": {
          "type": "string",
          "enum": [
            "received",
            "not-provided",
            "not-applicable"
          ]
        },
        "moodys_report_date": {
          "type": [
            "string",
            "null"
          ]
        },
        "orbis": {
          "type": "string",
          "enum": [
            "received",
            "not-provided",
            "not-applicable"
          ]
        },
        "orbis_report_date": {
          "type": [
            "string",
            "null"
          ]
        },
        "lexisnexis": {
          "type": "string",
          "enum": [
            "received",
            "not-provided",
            "not-applicable"
          ]
        },
        "lexisnexis_search_date": {
          "type": [
            "string",
            "null"
          ]
        },
        "company_registrar": {
          "type": "string",
          "enum": [
            "received",
            "not-provided",
            "not-applicable"
          ]
        },
        "registrar_jurisdiction": {
          "type": [
            "string",
            "null"
          ]
        },
        "stock_exchange_filings": {
          "type": "string",
          "enum": [
            "received",
            "not-provided",
            "not-applicable"
          ]
        },
        "news_media_review": {
          "type": "string",
          "enum": [
            "received",
            "not-provided"
          ]
        },
        "internal_watchlist": {
          "type": "string",
          "enum": [
            "received",
            "not-provided"
          ]
        },
        "prior_review_output": {
          "type": "string",
          "enum": [
            "received",
            "not-available-first-review",
            "not-available-unknown"
          ]
        },
        "onboarding_form": {
          "type": "string",
          "enum": [
            "received",
            "not-available"
          ]
        },
        "client_documents": {
          "type": "array",
          "description": "One entry per client-provided document received.",
          "items": {
            "type": "object",
            "required": [
              "document_type",
              "subject",
              "status",
              "verification_state",
              "confidence"
            ],
            "properties": {
              "document_type": {
                "type": "string"
              },
              "subject": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "received",
                  "not-provided",
                  "not-applicable"
                ]
              },
              "form_received": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "issue_date": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "expiry_date": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "recency_met": {
                "type": [
                  "boolean",
                  "null"
                ]
              },
              "verification_state": {
                "type": "string",
                "enum": [
                  "verified",
                  "unverified-source-not-available",
                  "discrepancy-found",
                  "not-applicable",
                  "pending"
                ]
              },
              "verification_source": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low",
                  "not-applicable"
                ]
              }
            }
          }
        }
      }
    },
    "dimension_confidence": {
      "type": "object",
      "description": "Overall confidence for each of the five assessment dimensions.",
      "required": [
        "identity_and_registration",
        "ownership_and_ubo",
        "pep_and_sanctions",
        "financial_risk",
        "document_compliance"
      ],
      "properties": {
        "identity_and_registration": {
          "type": "object",
          "properties": {
            "level": {
              "type": "string",
              "enum": [
                "full",
                "reduced",
                "limited",
                "not-assessed"
              ]
            },
            "available_sources": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "missing_sources": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "impact": {
              "type": "string"
            }
          }
        },
        "ownership_and_ubo": {
          "type": "object",
          "properties": {
            "level": {
              "type": "string",
              "enum": [
                "full",
                "reduced",
                "limited",
                "not-assessed"
              ]
            },
            "available_sources": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "missing_sources": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "impact": {
              "type": "string"
            }
          }
        },
        "pep_and_sanctions": {
          "type": "object",
          "properties": {
            "level": {
              "type": "string",
              "enum": [
                "full",
                "reduced",
                "limited",
                "not-assessed"
              ]
            },
            "available_sources": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "missing_sources": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "impact": {
              "type": "string"
            }
          }
        },
        "financial_risk": {
          "type": "object",
          "properties": {
            "level": {
              "type": "string",
              "enum": [
                "full",
                "reduced",
                "limited",
                "not-assessed"
              ]
            },
            "available_sources": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "missing_sources": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "impact": {
              "type": "string"
            }
          }
        },
        "document_compliance": {
          "type": "object",
          "properties": {
            "level": {
              "type": "string",
              "enum": [
                "full",
                "reduced",
                "limited",
                "not-assessed"
              ]
            },
            "available_sources": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "missing_sources": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "impact": {
              "type": "string"
            }
          }
        }
      }
    },
    "identity": {
      "type": "object",
      "properties": {
        "legal_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "legal_name_source": {
          "type": [
            "string",
            "null"
          ]
        },
        "legal_name_confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "not-assessed"
          ]
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "alias": {
                "type": "string"
              },
              "alias_type": {
                "type": "string"
              },
              "source": {
                "type": "string"
              }
            }
          }
        },
        "jurisdiction": {
          "type": [
            "string",
            "null"
          ]
        },
        "jurisdiction_source": {
          "type": [
            "string",
            "null"
          ]
        },
        "jurisdiction_confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "not-assessed"
          ]
        },
        "registration_number": {
          "type": [
            "string",
            "null"
          ]
        },
        "legal_form": {
          "type": [
            "string",
            "null"
          ]
        },
        "operational_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "date_of_incorporation": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ownership": {
      "type": "object",
      "properties": {
        "structure_summary": {
          "type": [
            "string",
            "null"
          ],
          "description": "Plain language. States source and confidence. States explicitly if based on client documents only with no independent corroboration."
        },
        "opacity_flag": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "opacity_percentage": {
          "type": [
            "number",
            "null"
          ]
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "full",
            "reduced",
            "limited",
            "not-assessed"
          ]
        }
      }
    },
    "ubos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "source",
          "confidence",
          "pep_status",
          "sanctions_status"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "new_since_last_review": {
            "type": "boolean"
          },
          "nationality": {
            "type": [
              "string",
              "null"
            ]
          },
          "country_of_residence": {
            "type": [
              "string",
              "null"
            ]
          },
          "ownership_percentage": {
            "type": [
              "number",
              "null"
            ]
          },
          "ownership_percentage_source": {
            "type": [
              "string",
              "null"
            ]
          },
          "pep_status": {
            "type": "object",
            "properties": {
              "determined": {
                "type": "boolean",
                "description": "False when LexisNexis not available."
              },
              "is_pep": {
                "type": [
                  "boolean",
                  "null"
                ]
              },
              "pep_category": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "source": {
                "type": "string"
              },
              "new_since_last_review": {
                "type": [
                  "boolean",
                  "null"
                ]
              }
            }
          },
          "sanctions_status": {
            "type": "object",
            "properties": {
              "determined": {
                "type": "boolean"
              },
              "outcome": {
                "type": [
                  "string",
                  "null"
                ],
                "enum": [
                  "clear",
                  "potential-match",
                  "confirmed-match",
                  null
                ]
              },
              "source": {
                "type": "string"
              },
              "new_since_last_review": {
                "type": [
                  "boolean",
                  "null"
                ]
              }
            }
          },
          "identity_documents_held": {
            "type": "string",
            "enum": [
              "fully-documented",
              "partially-documented",
              "not-documented"
            ]
          },
          "identity_verification_state": {
            "type": "string",
            "enum": [
              "verified",
              "unverified-source-not-available",
              "discrepancy-found",
              "not-applicable"
            ]
          }
        }
      }
    },
    "screening": {
      "type": "object",
      "properties": {
        "performed": {
          "type": "boolean"
        },
        "search_date": {
          "type": [
            "string",
            "null"
          ]
        },
        "overall_outcome": {
          "type": [
            "string",
            "null"
          ]
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "finding_id",
              "category",
              "matched_name",
              "status",
              "confirmed",
              "new_since_last_review"
            ],
            "properties": {
              "finding_id": {
                "type": "string"
              },
              "category": {
                "type": "string",
                "enum": [
                  "pep",
                  "sanctions",
                  "adverse-media",
                  "regulatory-action",
                  "law-enforcement",
                  "internal-watchlist",
                  "news-signal"
                ]
              },
              "source_tier": {
                "type": "string",
                "enum": [
                  "tier1",
                  "tier2"
                ]
              },
              "confirmed": {
                "type": "boolean",
                "description": "True for LexisNexis and official regulatory findings. False for news signals pending investigation."
              },
              "matched_name": {
                "type": "string"
              },
              "match_basis": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "status": {
                "type": "string",
                "enum": [
                  "confirmed",
                  "potential",
                  "signal-requires-investigation"
                ]
              },
              "summary": {
                "type": "string"
              },
              "new_since_last_review": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "financial_risk": {
      "type": "object",
      "properties": {
        "primary_source": {
          "type": [
            "string",
            "null"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "full",
            "reduced",
            "limited",
            "not-assessed"
          ]
        },
        "current_rating": {
          "type": [
            "string",
            "null"
          ]
        },
        "rating_change_direction": {
          "type": [
            "string",
            "null"
          ]
        },
        "outlook": {
          "type": [
            "string",
            "null"
          ]
        },
        "probability_of_default": {
          "type": [
            "number",
            "null"
          ]
        },
        "auditor_opinion": {
          "type": [
            "string",
            "null"
          ]
        },
        "auditor_qualification_flag": {
          "type": "boolean"
        },
        "report_date": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "document_type",
          "policy_rule_id",
          "status",
          "verification_state",
          "confidence"
        ],
        "properties": {
          "document_type": {
            "type": "string"
          },
          "policy_rule_id": {
            "type": "string"
          },
          "subject": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "collected",
              "outstanding",
              "expired",
              "waived",
              "approaching-expiry",
              "not-provided",
              "not-applicable"
            ]
          },
          "form_held": {
            "type": [
              "string",
              "null"
            ]
          },
          "issue_date": {
            "type": [
              "string",
              "null"
            ]
          },
          "expiry_date": {
            "type": [
              "string",
              "null"
            ]
          },
          "recency_met": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "verification_state": {
            "type": "string",
            "enum": [
              "verified",
              "unverified-source-not-available",
              "discrepancy-found",
              "not-applicable",
              "not-collected"
            ]
          },
          "verification_source": {
            "type": [
              "string",
              "null"
            ]
          },
          "chronic_outstanding": {
            "type": "boolean"
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low",
              "not-applicable"
            ]
          }
        }
      }
    },
    "client_stated": {
      "type": "object",
      "properties": {
        "purpose_of_relationship": {
          "type": "object",
          "properties": {
            "stated_value": {
              "type": [
                "string",
                "null"
              ]
            },
            "corroborated": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "corroborating_source": {
              "type": [
                "string",
                "null"
              ]
            },
            "discrepancy": {
              "type": [
                "boolean",
                "null"
              ]
            }
          }
        },
        "source_of_funds": {
          "type": "object",
          "properties": {
            "stated_value": {
              "type": [
                "string",
                "null"
              ]
            },
            "corroborated": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "corroborating_source": {
              "type": [
                "string",
                "null"
              ]
            },
            "discrepancy": {
              "type": [
                "boolean",
                "null"
              ]
            }
          }
        },
        "source_of_wealth": {
          "type": "object",
          "properties": {
            "stated_value": {
              "type": [
                "string",
                "null"
              ]
            },
            "corroborated": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "corroborating_source": {
              "type": [
                "string",
                "null"
              ]
            },
            "discrepancy": {
              "type": [
                "boolean",
                "null"
              ]
            }
          }
        },
        "anticipated_activity": {
          "type": "object",
          "properties": {
            "stated_value": {
              "type": [
                "string",
                "null"
              ]
            },
            "corroborated": {
              "type": [
                "boolean",
                "null"
              ]
            },
            "discrepancy": {
              "type": [
                "boolean",
                "null"
              ]
            }
          }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "conflict_id",
          "data_point",
          "source_a",
          "value_a",
          "source_b",
          "value_b",
          "governing_source",
          "governing_value"
        ],
        "properties": {
          "conflict_id": {
            "type": "string"
          },
          "data_point": {
            "type": "string"
          },
          "source_a": {
            "type": "string"
          },
          "source_a_tier": {
            "type": "string",
            "enum": [
              "tier1",
              "tier2",
              "tier3",
              "tier4"
            ]
          },
          "value_a": {
            "type": "string"
          },
          "source_b": {
            "type": "string"
          },
          "source_b_tier": {
            "type": "string",
            "enum": [
              "tier1",
              "tier2",
              "tier3",
              "tier4"
            ]
          },
          "value_b": {
            "type": "string"
          },
          "governing_source": {
            "type": "string"
          },
          "governing_value": {
            "type": "string"
          },
          "governing_source_confidence": {
            "type": "string",
            "enum": [
              "full",
              "reduced",
              "limited"
            ]
          },
          "risk_implication": {
            "type": [
              "string",
              "null"
            ]
          },
          "reviewer_confirmation_required": {
            "type": "boolean"
          }
        }
      }
    },
    "data_quality_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "flag_id",
          "flag_type",
          "affected_source",
          "impact",
          "resolution_required"
        ],
        "properties": {
          "flag_id": {
            "type": "string"
          },
          "flag_type": {
            "type": "string",
            "enum": [
              "unclassified-document",
              "low-extraction-confidence",
              "illegible-section",
              "source-not-searchable",
              "uncertain-classification",
              "source-newly-absent",
              "conflicting-client-documents"
            ]
          },
          "affected_source": {
            "type": "string"
          },
          "affected_field": {
            "type": [
              "string",
              "null"
            ]
          },
          "impact": {
            "type": "string"
          },
          "resolution_required": {
            "type": "string"
          }
        }
      }
    }
  }
}